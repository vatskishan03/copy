{
    "compilerOptions": {
      "target": "ES2016",
      "module": "CommonJS",
      "strict": true,
      "rootDir": "./src",
      "outDir": "./dist",
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "baseUrl": ".",
      "paths": {
        "*": ["node_modules/*"]
      },
      // "noImplicitAny":false,
      // }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules"]
  }
