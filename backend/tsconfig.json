{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": ["es2022"],
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": "./src"
    },
    "include": ["src/**/*.ts"]
}
